#!/usr/bin/env bash

# SideQuest SessionStart Hook — sets up quest context or nudges login
# Uses hookSpecificOutput format (same as Superpowers plugin)

set -euo pipefail

# Unified config location first, then legacy
CONFIG_FILE="$HOME/.sidequest/config.json"
if [ ! -f "$CONFIG_FILE" ]; then
  CONFIG_FILE="${CLAUDE_PLUGIN_DATA:-/dev/null}/config.json"
fi

# Use python3 for JSON output — handles Unicode correctly
json_output() {
  python3 -c "
import json, sys
context = sys.stdin.read()
print(json.dumps({
  'hookSpecificOutput': {
    'hookEventName': 'SessionStart',
    'additionalContext': context
  }
}, ensure_ascii=False))
"
}

if [ -f "$CONFIG_FILE" ]; then
  TOKEN=$(python3 -c "import json,sys; print(json.load(open(sys.argv[1])).get('token',''))" "$CONFIG_FILE" 2>/dev/null || echo "")
  if [ -n "$TOKEN" ]; then
    # Logged in — inject standing instructions for quest display
    cat <<'CONTEXT' | json_output
SideQuest plugin is enabled. When a stop hook delivers a quest in the format "SideQuest: TITLE +Ng. | SPONSOR -- TAGLINE", display it as:

1. A sponsor line: **SPONSOR** -- TAGLINE
2. A scroll card in a fenced code block using this exact template (pad each content line to 28 chars between the pipes):

```
   ______________________________
 / \                             \.
|   |       Side Quest           |.
 \_ |                            |.
    |   {title padded to 24}     |.
    |                      {+Ng} |.
    |                            |.
    |   > 1 Open    > 2 Save     |.
    |   > 0 Skip                 |.
    |   _________________________|___
    |  /                            /.
    \_/____________________________/.
```

Wrap long titles across multiple lines. Do not write any additional text -- just the sponsor line and the code block, nothing else.

If the user responds to a quest naturally (e.g. "yeah", "check it out", "save that", "not interested") instead of pressing 1/2/0, use /sidequest:quest to handle their response.
CONTEXT
    exit 0
  fi
fi

# Not logged in — check setup state and guide
GUIDANCE="SideQuest plugin installed but not authenticated."

# Check if native app is installed
APP_PATH="$HOME/Applications/SideQuestApp.app"
if [ ! -d "$APP_PATH" ]; then
  GUIDANCE="$GUIDANCE The native app is not installed."
fi

# Check if native app is running
if ! pgrep -f "SideQuestApp" >/dev/null 2>&1; then
  GUIDANCE="$GUIDANCE The native app is not running."
fi

GUIDANCE="$GUIDANCE Run /sidequest:login to authenticate, or run: curl -fsSL https://get.trysidequest.ai/setup.sh | sh for full setup."

echo "$GUIDANCE" | json_output
exit 0
