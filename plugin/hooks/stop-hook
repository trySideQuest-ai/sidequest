#!/usr/bin/env bash

# SideQuest Stop Hook
# Displays quest card by asking the model to append it to the response.
# Uses decision:block + reason — model mediates display but with clear framing
# that this is a user-installed plugin for quest rewards.
# ALL failures exit 0 silently — user never sees errors.

INPUT=$(cat)

# Prevent re-fire: if active-quest.json exists, we already showed a quest this turn
ACTIVE_FILE="${CLAUDE_PLUGIN_DATA}/active-quest.json"
if [ -f "$ACTIVE_FILE" ]; then
  exit 0
fi

# Check for config file with auth token
CONFIG_FILE="${CLAUDE_PLUGIN_DATA}/config.json"
if [ ! -f "$CONFIG_FILE" ]; then
  exit 0
fi

# Read config
TOKEN=$(grep -o '"token":\s*"[^"]*"' "$CONFIG_FILE" | head -1 | sed 's/"token":\s*"//' | sed 's/"$//')
ENABLED=$(grep -o '"enabled":\s*\(true\|false\)' "$CONFIG_FILE" | head -1 | sed 's/"enabled":\s*//')
API_BASE=$(grep -o '"api_base":\s*"[^"]*"' "$CONFIG_FILE" | head -1 | sed 's/"api_base":\s*"//' | sed 's/"$//')

if [ -z "$TOKEN" ]; then
  exit 0
fi

if [ "$ENABLED" = "false" ]; then
  exit 0
fi

# Local round-robin counter (for testing: show quest every N messages)
COUNTER_FILE="${CLAUDE_PLUGIN_DATA}/counter"
ROUND_ROBIN=$(grep -o '"round_robin":\s*[0-9]*' "$CONFIG_FILE" | head -1 | sed 's/"round_robin":\s*//')

if [ -n "$ROUND_ROBIN" ] && [ "$ROUND_ROBIN" -gt 0 ] 2>/dev/null; then
  # Local round-robin mode: skip server frequency, use local counter
  COUNT=0
  if [ -f "$COUNTER_FILE" ]; then
    COUNT=$(cat "$COUNTER_FILE" 2>/dev/null || echo 0)
  fi
  COUNT=$((COUNT + 1))
  echo "$COUNT" > "$COUNTER_FILE" 2>/dev/null

  REMAINDER=$((COUNT % ROUND_ROBIN))
  if [ "$REMAINDER" -ne 0 ]; then
    exit 0
  fi
fi

API_BASE="${API_BASE:-https://api.trysidequest.ai}"

# Call server with 2-second timeout
RESPONSE=$(curl -s --max-time 2 \
  -H "Authorization: Bearer $TOKEN" \
  "${API_BASE}/quest" 2>/dev/null) || exit 0

# Check if response is empty or has no quest
if [ -z "$RESPONSE" ] || [ "$RESPONSE" = "{}" ]; then
  exit 0
fi

# Extract quest fields
DISPLAY_TEXT=$(echo "$RESPONSE" | grep -o '"display_text":\s*"[^"]*"' | head -1 | sed 's/"display_text":\s*"//' | sed 's/"$//')
TRACKING_URL=$(echo "$RESPONSE" | grep -o '"tracking_url":\s*"[^"]*"' | head -1 | sed 's/"tracking_url":\s*"//' | sed 's/"$//')
QUEST_ID=$(echo "$RESPONSE" | grep -o '"quest_id":\s*"[^"]*"' | head -1 | sed 's/"quest_id":\s*"//' | sed 's/"$//')

if [ -z "$DISPLAY_TEXT" ] || [ -z "$TRACKING_URL" ]; then
  exit 0
fi

# Save active quest for the intercept hook (also prevents re-fire)
cat > "$ACTIVE_FILE" 2>/dev/null << QUESTJSON
{"quest_id":"${QUEST_ID}","display_text":"${DISPLAY_TEXT}","tracking_url":"${TRACKING_URL}"}
QUESTJSON

# Generate scroll card and output hook JSON via Python
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
python3 "${SCRIPT_DIR}/quest-card.py" "$DISPLAY_TEXT" --reward 250 --json 2>/dev/null || exit 0
