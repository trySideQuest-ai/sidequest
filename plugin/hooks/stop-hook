#!/usr/bin/env bash

# SideQuest Stop Hook
# Displays quest card by asking the model to append it to the response.
# Uses decision:block + reason — model mediates display but with clear framing
# that this is a user-installed plugin for quest rewards.
# ALL failures exit 0 silently — user never sees errors.

INPUT=$(cat)

# Active quest tracking (re-fire guard disabled for testing)
ACTIVE_FILE="${CLAUDE_PLUGIN_DATA}/active-quest.json"

# Check for config file with auth token (unified location first, then legacy)
CONFIG_FILE="$HOME/.sidequest/config.json"
if [ ! -f "$CONFIG_FILE" ]; then
  CONFIG_FILE="${CLAUDE_PLUGIN_DATA}/config.json"
  if [ ! -f "$CONFIG_FILE" ]; then
    exit 0
  fi
fi

# Read config (use python3 for reliable JSON parsing)
eval "$(python3 -c "
import json, shlex, sys
try:
    with open(sys.argv[1]) as f:
        c = json.load(f)
    print(f'TOKEN={shlex.quote(str(c.get(\"token\",\"\")))}')
    print(f'ENABLED={shlex.quote(str(c.get(\"enabled\",True)).lower())}')
    print(f'API_BASE={shlex.quote(str(c.get(\"api_base\",\"\")))}')
    print(f'ROUND_ROBIN={c.get(\"round_robin\",0)}')
except: pass
" "$CONFIG_FILE" 2>/dev/null)"

if [ -z "$TOKEN" ]; then
  exit 0
fi

if [ "$ENABLED" = "false" ]; then
  exit 0
fi

# Local round-robin counter (for testing: show quest every N messages)
COUNTER_FILE="${CLAUDE_PLUGIN_DATA}/counter"

if [ -n "$ROUND_ROBIN" ] && [ "$ROUND_ROBIN" -gt 0 ] 2>/dev/null; then
  # Local round-robin mode: skip server frequency, use local counter
  COUNT=0
  if [ -f "$COUNTER_FILE" ]; then
    COUNT=$(cat "$COUNTER_FILE" 2>/dev/null || echo 0)
  fi
  COUNT=$((COUNT + 1))
  echo "$COUNT" > "$COUNTER_FILE" 2>/dev/null

  REMAINDER=$((COUNT % ROUND_ROBIN))
  if [ "$REMAINDER" -ne 0 ]; then
    exit 0
  fi
fi

API_BASE="${API_BASE:-https://api.trysidequest.ai}"

# Call server with 2-second timeout
RESPONSE=$(curl -s --max-time 2 \
  -H "Authorization: Bearer $TOKEN" \
  "${API_BASE}/quest" 2>/dev/null) || exit 0

# Check if response is empty or has no quest
if [ -z "$RESPONSE" ] || [ "$RESPONSE" = "{}" ]; then
  exit 0
fi

# Extract quest fields (use python3 for reliable JSON parsing)
eval "$(echo "$RESPONSE" | python3 -c "
import json, shlex, sys
try:
    r = json.load(sys.stdin)
    for k in ('display_text','subtitle','tracking_url','quest_id','reward_amount','brand_name','category'):
        v = r.get(k, '')
        print(f'{k.upper()}={shlex.quote(str(v))}')
except: pass
" 2>/dev/null)"

if [ -z "$DISPLAY_TEXT" ] || [ -z "$TRACKING_URL" ]; then
  exit 0
fi

# Save active quest for the intercept hook (also prevents re-fire)
cat > "$ACTIVE_FILE" 2>/dev/null << QUESTJSON
{"quest_id":"${QUEST_ID}","display_text":"${DISPLAY_TEXT}","subtitle":"${SUBTITLE}","tracking_url":"${TRACKING_URL}","reward_amount":${REWARD_AMOUNT:-250},"brand_name":"${BRAND_NAME:-Unknown}","category":"${CATEGORY:-DevTool}"}
QUESTJSON

# Save last quest for retrigger skill (use ~/.sidequest/ so skills can find it)
mkdir -p "$HOME/.sidequest" 2>/dev/null
cat > "$HOME/.sidequest/last-quest.json" 2>/dev/null << LASTJSON
{"quest_id":"${QUEST_ID}","display_text":"${DISPLAY_TEXT}","subtitle":"${SUBTITLE}","tracking_url":"${TRACKING_URL}","reward_amount":${REWARD_AMOUNT:-250},"brand_name":"${BRAND_NAME:-Unknown}","category":"${CATEGORY:-DevTool}"}
LASTJSON

# IPC trigger to native app (sends full quest data)
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
"${SCRIPT_DIR}/xpc-socket-helper.sh" "$QUEST_ID" "$QUEST_ID" "$DISPLAY_TEXT" "$SUBTITLE" "$TRACKING_URL" "${REWARD_AMOUNT:-250}" "${BRAND_NAME:-Unknown}" "${CATEGORY:-DevTool}" 2>/dev/null || true

exit 0
