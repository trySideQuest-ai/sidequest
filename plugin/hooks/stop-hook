#!/usr/bin/env bash

# SideQuest Stop Hook — Quest Timing Redesign
# Phase 19: Two triggers (git commit OR 10min gap), hard caps (20min cooldown, 5/day)
# Two-layer context extraction (static + dynamic), IPC socket connection test
# ALL failures exit 0 silently — user never sees errors.

# Validate python3 exists (required for JSON parsing and file I/O)
command -v python3 >/dev/null 2>&1 || exit 0

# ============================================================================
# PHASE 1: Load config and establish error logging
# ============================================================================

CONFIG_FILE="$HOME/.sidequest/config.json"
if [ ! -f "$CONFIG_FILE" ]; then
  CONFIG_FILE="${CLAUDE_PLUGIN_DATA}/config.json"
  if [ ! -f "$CONFIG_FILE" ]; then
    exit 0
  fi
fi

# Error logging helper
log_error() {
  echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] $1" >> "$HOME/.sidequest/hook-errors.log" 2>/dev/null
  # Truncate log if over 100KB to prevent disk bloat
  if [ -f "$HOME/.sidequest/hook-errors.log" ]; then
    SIZE=$(stat -f%z "$HOME/.sidequest/hook-errors.log" 2>/dev/null || echo 0)
    if [ "$SIZE" -gt 102400 ]; then
      tail -n 500 "$HOME/.sidequest/hook-errors.log" > "$HOME/.sidequest/hook-errors.log.tmp"
      mv "$HOME/.sidequest/hook-errors.log.tmp" "$HOME/.sidequest/hook-errors.log" 2>/dev/null
    fi
  fi
}

# Read config (use python3 for reliable JSON parsing)
eval "$(python3 -c "
import json, shlex, sys
try:
    with open(sys.argv[1]) as f:
        c = json.load(f)
    print(f'TOKEN={shlex.quote(str(c.get(\"token\",\"\")))}')
    print(f'ENABLED={shlex.quote(str(c.get(\"enabled\",True)).lower())}')
    print(f'API_BASE={shlex.quote(str(c.get(\"api_base\",\"\")))}')
    print(f'DO_NOT_DISTURB={shlex.quote(str(c.get(\"do_not_disturb\",\"\")))}')
except Exception as e:
    import sys
    print('ERROR_CONFIG=parse_failed')
" "$CONFIG_FILE" 2>/dev/null)"

if [ "$ERROR_CONFIG" = "parse_failed" ]; then
  log_error "Config parse error: $CONFIG_FILE"
  exit 0
fi

if [ -z "$TOKEN" ]; then
  exit 0
fi

if [ "$ENABLED" = "false" ]; then
  exit 0
fi

# Check Do Not Disturb mode
if [ -n "$DO_NOT_DISTURB" ]; then
  NOW=$(date +%s)
  if [ "$NOW" -lt "$DO_NOT_DISTURB" ]; then
    exit 0
  fi
fi

API_BASE="${API_BASE:-https://api.trysidequest.ai}"

# ============================================================================
# Liveness ping — fires before any gate so every authenticated turn is observable.
# Best-effort: 2s timeout, errors swallowed, runs in background.
# ============================================================================

sq_ping() {
  local plugin_dir version
  plugin_dir="$(cd "$(dirname "$0")" && pwd)"
  version="unknown"
  if [ -f "$plugin_dir/../VERSION" ]; then
    version=$(tr -d '[:space:]' < "$plugin_dir/../VERSION" 2>/dev/null || echo unknown)
    [ -z "$version" ] && version="unknown"
  fi

  curl -sS -m 2 -X POST "$API_BASE/ping" \
    -H "Authorization: Bearer $TOKEN" \
    -H "Content-Type: application/json" \
    -d "{\"client_version\":\"$version\",\"source\":\"plugin\"}" \
    >/dev/null 2>&1 &
  disown 2>/dev/null || true
  return 0
}

sq_ping || true

# ============================================================================
# Welcome quest — fires once on first stop-hook after install. Pushes a
# hardcoded card via IPC, marks ~/.sidequest/welcome-shown, exits.
#
# Sentinel UUID 00000000-0000-0000-0000-000000000001 is a real DB row
# with active=false (excluded from ranking SQL but valid FK target so
# events table inserts succeed).
#
# If the socket isn't ready (app still bootstrapping ~30s on first run),
# we still mark welcome-shown so normal quests aren't blocked forever.
# ============================================================================

WELCOME_MARKER="$HOME/.sidequest/welcome-shown"
if [ ! -f "$WELCOME_MARKER" ]; then
  WELCOME_SOCKET="$HOME/.sidequest/sidequest.sock"
  SCRIPT_DIR_HOOKS="$(cd "$(dirname "$0")" && pwd)"
  if [ -S "$WELCOME_SOCKET" ]; then
    "${SCRIPT_DIR_HOOKS}/xpc-socket-helper.sh" \
      "00000000-0000-0000-0000-000000000001" \
      "00000000-0000-0000-0000-000000000001" \
      "Welcome to SideQuest" \
      "Side quests appear as you code. Tools matched to what you're building. Pick up or keep grinding." \
      "https://github.com/trysidequest-ai/sidequest" \
      "0" "SideQuest" "Onboarding" "" "" 2>/dev/null
    # Cache for /sidequest:sq-retrigger
    mkdir -p "$HOME/.sidequest" 2>/dev/null
    cat > "$HOME/.sidequest/last-quest.json" <<'JSON' 2>/dev/null
{
  "quest_id": "00000000-0000-0000-0000-000000000001",
  "display_text": "Welcome to SideQuest",
  "subtitle": "Side quests appear as you code. Tools matched to what you're building. Pick up or keep grinding.",
  "tracking_url": "https://github.com/trysidequest-ai/sidequest",
  "reward_amount": 0,
  "brand_name": "SideQuest",
  "category": "Onboarding"
}
JSON
  fi
  touch "$WELCOME_MARKER" 2>/dev/null
  exit 0
fi

# ============================================================================
# Counter + timing-state read (replaces phases 1.5, 1.6, 2, 3)
#
# Single rule: increment "messages since last quest"; fire only after every
# QUEST_EVERY_N user turns. No git/time triggers, no session-depth gate, no
# advisory lock. Daily cap is enforced in PHASE 4.5 below; counter is reset
# in PHASE 9 after a quest is delivered.
# ============================================================================

QUEST_EVERY_N=5

TIMING_FILE="$HOME/.sidequest/timing-state.json"
CURRENT_TIME=$(date +%s)
COUNTER=0

eval "$(python3 -c "
# F-string expressions used to have commas (e.g. {int(t.get('k', 0))}),
# which bash brace-expanded inside the \$(...) substitution and corrupted
# the source. Pre-compute every value into a bare variable so each f-string
# brace contains a single identifier — no commas, no expansion bug.
import json, os, tempfile
f = os.path.expanduser('~/.sidequest/timing-state.json')
try:
    with open(f) as fp:
        t = json.load(fp)
except Exception:
    t = dict()

count = int(t.get('messages_since_last_quest', 0)) + 1
t['messages_since_last_quest'] = count

# Atomic write so a concurrent hook can't see a half-written counter
d = os.path.dirname(f)
os.makedirs(d, exist_ok=True)
try:
    fd, tmp = tempfile.mkstemp(dir=d)
    with os.fdopen(fd, 'w') as fp:
        json.dump(t, fp)
    os.rename(tmp, f)
except Exception:
    pass

print(f'COUNTER={count}')
" 2>/dev/null)"

if [ "$COUNTER" -lt "$QUEST_EVERY_N" ]; then
  exit 0
fi

# ============================================================================
# PHASE 4: Load remote config (cached locally, fallback to defaults)
# ============================================================================

REMOTE_CONFIG_FILE="$HOME/.sidequest/remote-config.json"
RC_ENABLED="true"

# Daily cap is server-side now (server/src/quest.js). Plugin only reads
# the global enabled kill switch from remote-config.
if [ -f "$REMOTE_CONFIG_FILE" ]; then
  eval "$(python3 -c "
import json, shlex, sys
try:
    with open(sys.argv[1]) as f:
        rc = json.load(f)
    print(f'RC_ENABLED={shlex.quote(str(rc.get(\"enabled\", True)).lower())}')
except:
    pass
" "$REMOTE_CONFIG_FILE" 2>/dev/null)"
fi

# Kill switch: remote config can disable all quests globally
if [ "$RC_ENABLED" = "false" ]; then
  exit 0
fi

# ============================================================================
# Daily cap is enforced server-side (server/src/quest.js:countShownLast24h
# vs users.daily_cap), so the plugin no longer keeps its own daily counter.
# Removing the local counter eliminates the plugin↔app drift bug.
# ============================================================================

# ============================================================================
# PHASE 4.9: Extract last user and assistant messages for embedding inference
# Reads Claude CLI session state (.jsonl) to get message context for tokenization
# Messages truncated to 1024 chars each (increased from 500); passed to native app for ANE inference
# ============================================================================

LAST_MESSAGES='{"user_msg":"","asst_msg":""}'

LAST_MESSAGES=$(python3 -c "
import json, os, sys
from pathlib import Path

cwd = os.getcwd()
projects_dir = os.path.expanduser(f'~/.claude/projects/{os.path.abspath(cwd).replace(\"/\", \"-\")}')

# Find latest .jsonl
if os.path.isdir(projects_dir):
  try:
    jsonl_files = [f for f in os.listdir(projects_dir) if f.endswith('.jsonl')]
    if jsonl_files:
      jsonl_files.sort(key=lambda f: os.path.getmtime(os.path.join(projects_dir, f)), reverse=True)
      latest_jsonl = os.path.join(projects_dir, jsonl_files[0])

      user_msg = ''
      asst_msg = ''

      # Read .jsonl and extract last user + asst messages
      try:
        with open(latest_jsonl) as f:
          for line in f:
            try:
              obj = json.loads(line.strip())
              kind = obj.get('type')
              if kind in ('user', 'assistant'):
                msg = obj.get('message', {})
                content = msg.get('content')

                # Extract text from content (string or list of parts)
                text = ''
                if isinstance(content, str):
                  text = content
                elif isinstance(content, list):
                  text = ' '.join(p.get('text', '') for p in content if isinstance(p, dict) and p.get('type') == 'text')

                if text:
                  # Truncate to 1024 chars (per IPC-01, increased from 500)
                  text = text[:1024]
                  if kind == 'user':
                    user_msg = text
                  else:
                    asst_msg = text
            except json.JSONDecodeError:
              pass
      except (IOError, PermissionError):
        pass

      print(json.dumps({'user_msg': user_msg, 'asst_msg': asst_msg}))
    else:
      print(json.dumps({'user_msg': '', 'asst_msg': ''}))
  except OSError:
    print(json.dumps({'user_msg': '', 'asst_msg': ''}))
else:
  print(json.dumps({'user_msg': '', 'asst_msg': ''}))
" 2>/dev/null) || LAST_MESSAGES='{"user_msg":"","asst_msg":""}'

# ============================================================================
# PHASE 5: Deep context extraction (v1.7 data-driven pipeline)
# Reads all 4 sources: conversation, diff content, git metadata, config cache
# Patterns, weights, and domains are data in config/*.json — not code
# ============================================================================

SCRIPT_DIR_CTX="$(cd "$(dirname "$0")" && pwd)"
CONTEXT_RESULT='{"weighted_tags":[],"domain":null}'

# SRC-01: Read actual diff content (not just file names), capped at 50KB
SIDEQUEST_DIFF=""
if git rev-parse --git-dir >/dev/null 2>&1; then
  SIDEQUEST_DIFF=$(perl -e 'alarm 1; exec @ARGV' -- git diff HEAD~1 2>/dev/null | head -c 51200) || SIDEQUEST_DIFF=""
fi
export SIDEQUEST_DIFF

# SRC-03: Read git branch name and most recent commit message
SIDEQUEST_BRANCH=""
SIDEQUEST_COMMIT_MSG=""
if git rev-parse --git-dir >/dev/null 2>&1; then
  SIDEQUEST_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) || SIDEQUEST_BRANCH=""
  SIDEQUEST_COMMIT_MSG=$(git log -1 --format=%s 2>/dev/null) || SIDEQUEST_COMMIT_MSG=""
fi
export SIDEQUEST_BRANCH SIDEQUEST_COMMIT_MSG

# SRC-02: Run full extraction (conversation + diff + git metadata + config cache)
HISTORY_FILE="$HOME/.claude/history.jsonl"
CONTEXT_RESULT=$(python3 "${SCRIPT_DIR_CTX}/extract-context.py" --mode full "$HISTORY_FILE" "$(pwd)" 2>/dev/null) || CONTEXT_RESULT='{"weighted_tags":[],"domain":null}'

# SAFE-04: Unset diff content immediately — never persists beyond this script
unset SIDEQUEST_DIFF SIDEQUEST_BRANCH SIDEQUEST_COMMIT_MSG

# ============================================================================
# PHASE 6: Test IPC socket connection
# ============================================================================

SOCKET_PATH="$HOME/.sidequest/sidequest.sock"
if [ ! -S "$SOCKET_PATH" ] || ! echo "" | nc -U -w1 "$SOCKET_PATH" 2>/dev/null; then
  # Socket exists but app isn't responding — stale socket or hung app
  log_error "Socket connection failed: $SOCKET_PATH"
  exit 0
fi

# ============================================================================
# PHASE 6.5: Extract embed vectors via IPC (WIRE-01)
# Sends last user/asst messages to native app, receives 2x384-dim vectors,
# packages them for the /quest body. Any failure (timeout, malformed
# response, missing utils) leaves $VECTORS as null sentinels so PHASE 7
# falls back to tag-only ranking. Hook still exits 0 silently per privacy
# principle. Must run BEFORE PHASE 7 because vectors get injected into
# the /quest POST body, not the IPC quest delivery.
# ============================================================================

SCRIPT_DIR_HOOKS="$(cd "$(dirname "$0")" && pwd)"

USER_MSG=$(echo "$LAST_MESSAGES" | python3 -c "import json, sys; obj = json.load(sys.stdin); print(obj.get('user_msg', ''))" 2>/dev/null) || USER_MSG=""
ASST_MSG=$(echo "$LAST_MESSAGES" | python3 -c "import json, sys; obj = json.load(sys.stdin); print(obj.get('asst_msg', ''))" 2>/dev/null) || ASST_MSG=""

VECTORS='{"user_vec":null,"asst_vec":null}'
INFERENCE_MS=""

if [ -n "$USER_MSG" ] || [ -n "$ASST_MSG" ]; then
  IPC_REQUEST=$(SCRIPT_DIR_HOOKS="$SCRIPT_DIR_HOOKS" USER_MSG="$USER_MSG" ASST_MSG="$ASST_MSG" python3 -c "
import json, os, sys
sys.path.insert(0, os.environ.get('SCRIPT_DIR_HOOKS', ''))
try:
    from ipc_utils import build_ipc_request
    payload = build_ipc_request(user_msg=os.environ.get('USER_MSG', ''), asst_msg=os.environ.get('ASST_MSG', ''))
    print(json.dumps(payload))
except Exception:
    print('{}')
" 2>/dev/null) || IPC_REQUEST=''

  if [ -n "$IPC_REQUEST" ] && [ "$IPC_REQUEST" != "{}" ]; then
    IPC_T_START=$(python3 -c "import time; print(int(time.time()*1000))" 2>/dev/null || echo 0)
    IPC_RESPONSE=$(printf '%s' "$IPC_REQUEST" | nc -U -w 2 "$SOCKET_PATH" 2>/dev/null) || IPC_RESPONSE=''
    IPC_T_END=$(python3 -c "import time; print(int(time.time()*1000))" 2>/dev/null || echo 0)
    if [ "$IPC_T_START" -gt 0 ] && [ "$IPC_T_END" -gt "$IPC_T_START" ]; then
      INFERENCE_MS=$((IPC_T_END - IPC_T_START))
    fi

    if [ -n "$IPC_RESPONSE" ]; then
      VECTORS=$(SCRIPT_DIR_HOOKS="$SCRIPT_DIR_HOOKS" IPC_RESPONSE="$IPC_RESPONSE" python3 -c "
import json, os, sys
sys.path.insert(0, os.environ.get('SCRIPT_DIR_HOOKS', ''))
try:
    from ipc_utils import validate_ipc_response, extract_vectors_for_server
    resp = json.loads(os.environ.get('IPC_RESPONSE', ''))
    if validate_ipc_response(resp):
        print(json.dumps(extract_vectors_for_server(resp)))
    else:
        print(json.dumps({'user_vec': None, 'asst_vec': None}))
except Exception:
    print(json.dumps({'user_vec': None, 'asst_vec': None}))
" 2>/dev/null) || VECTORS='{"user_vec":null,"asst_vec":null}'
    fi
  fi
fi

# ============================================================================
# PHASE 6.6: Compose client_version (plugin VERSION + app CFBundleShortVersionString)
# Used by /quest payload for ANALYTICS-04 observability. Server records both
# client_version + inference_ms in events.metadata; missing values record null.
# ============================================================================

PLUGIN_VERSION_FILE="${SCRIPT_DIR_HOOKS}/../VERSION"
PLUGIN_VERSION="unknown"
if [ -f "$PLUGIN_VERSION_FILE" ]; then
  PLUGIN_VERSION=$(tr -d '[:space:]' < "$PLUGIN_VERSION_FILE" 2>/dev/null || echo "unknown")
  [ -z "$PLUGIN_VERSION" ] && PLUGIN_VERSION="unknown"
fi

APP_VERSION="unknown"
# App ships under SideQuestApp.app at ~/Applications/. Old path
# /Applications/SideQuest.app dates from pre-rename planning and never
# matched a real install, so APP_VERSION was always "unknown" in
# /events metadata.
APP_PLIST="$HOME/Applications/SideQuestApp.app/Contents/Info.plist"
if [ -f "$APP_PLIST" ]; then
  APP_VERSION=$(defaults read "$APP_PLIST" CFBundleShortVersionString 2>/dev/null | tr -d '[:space:]' || echo "unknown")
  [ -z "$APP_VERSION" ] && APP_VERSION="unknown"
fi

CLIENT_VERSION="plugin-${PLUGIN_VERSION}+app-${APP_VERSION}"

# ============================================================================
# PHASE 7: Fetch quest from API
# ============================================================================

# Build request body:
#   { tags: [{slug, weight, source, age_min}], freshness, user_vec?, asst_vec? }
REQUEST_BODY=$(python3 -c "
import json, sys
try:
    result = json.loads(sys.argv[1])
except Exception:
    result = {}
tags = result.get('weighted_tags', []) or []
# Server expects slug key; extract-context emits both tag and slug for compat.
serialized_tags = [
    {
        'slug': t.get('slug') or t.get('tag'),
        'weight': t.get('weight', 0),
        'source': t.get('source', ''),
        'age_min': t.get('age_min', 0),
    }
    for t in tags if (t.get('slug') or t.get('tag'))
]
body = {
    'tags': serialized_tags,
    'freshness': result.get('freshness', 0.0),
}
try:
    vectors = json.loads(sys.argv[2])
except Exception:
    vectors = {}
if vectors.get('user_vec'):
    body['user_vec'] = vectors['user_vec']
if vectors.get('asst_vec'):
    body['asst_vec'] = vectors['asst_vec']
client_version = sys.argv[3] if len(sys.argv) > 3 else ''
if client_version:
    body['client_version'] = client_version
inference_ms_arg = sys.argv[4] if len(sys.argv) > 4 else ''
if inference_ms_arg:
    try:
        ms = int(inference_ms_arg)
        if 0 <= ms <= 10000:
            body['inference_ms'] = ms
    except ValueError:
        pass
print(json.dumps(body))
" "$CONTEXT_RESULT" "$VECTORS" "$CLIENT_VERSION" "$INFERENCE_MS" 2>/dev/null) || REQUEST_BODY='{"tags":[],"freshness":0}'

RESPONSE=$(curl -s --max-time 5 \
  -H "Authorization: Bearer $TOKEN" \
  -H "Content-Type: application/json" \
  -X POST \
  -d "$REQUEST_BODY" \
  "${API_BASE}/quest" 2>/dev/null) || {
  log_error "API call failed: $API_BASE/quest"
  exit 0
}

# Check if response is empty or has no quest
if [ -z "$RESPONSE" ] || [ "$RESPONSE" = "{}" ]; then
  exit 0
fi

# Extract quest fields (use python3 for reliable JSON parsing)
eval "$(echo "$RESPONSE" | python3 -c "
import json, shlex, sys
try:
    r = json.load(sys.stdin)
    for k in ('display_text','subtitle','tracking_url','quest_id','reward_amount','brand_name','category'):
        v = r.get(k, '')
        print(f'{k.upper()}={shlex.quote(str(v))}')
except Exception as e:
    import sys
    print('ERROR_RESPONSE=parse_failed')
" 2>/dev/null)"

if [ "$ERROR_RESPONSE" = "parse_failed" ]; then
  log_error "Quest response parse error"
  exit 0
fi

if [ -z "$DISPLAY_TEXT" ] || [ -z "$TRACKING_URL" ]; then
  exit 0
fi

# ============================================================================
# PHASE 8: Send quest via IPC socket to native app
# USER_MSG / ASST_MSG already extracted in PHASE 6.5 above; SCRIPT_DIR_HOOKS
# already resolved there. Don't re-derive — single source of truth keeps the
# two IPC payloads (embed_request + quest_send) consistent.
# ============================================================================

"${SCRIPT_DIR_HOOKS}/xpc-socket-helper.sh" "$QUEST_ID" "$QUEST_ID" "$DISPLAY_TEXT" "$SUBTITLE" "$TRACKING_URL" "${REWARD_AMOUNT:-250}" "${BRAND_NAME:-Unknown}" "${CATEGORY:-DevTool}" "$USER_MSG" "$ASST_MSG" 2>/dev/null || {
  log_error "Socket send failed for quest: $QUEST_ID"
  exit 0
}

# Save last quest for retrigger skill (use ~/.sidequest/ so skills can find it)
mkdir -p "$HOME/.sidequest" 2>/dev/null
python3 -c "
import json, sys, os, tempfile
quest = {
    'quest_id': sys.argv[1],
    'display_text': sys.argv[2],
    'subtitle': sys.argv[3],
    'tracking_url': sys.argv[4],
    'reward_amount': int(sys.argv[5]),
    'brand_name': sys.argv[6],
    'category': sys.argv[7]
}
temp_fd, temp_path = tempfile.mkstemp(dir=os.path.expanduser('~/.sidequest'))
try:
    with os.fdopen(temp_fd, 'w') as f:
        json.dump(quest, f)
    os.rename(temp_path, os.path.expanduser('~/.sidequest/last-quest.json'))
except:
    try: os.unlink(temp_path)
    except: pass
" "$QUEST_ID" "$DISPLAY_TEXT" "$SUBTITLE" "$TRACKING_URL" "${REWARD_AMOUNT:-250}" "${BRAND_NAME:-Unknown}" "${CATEGORY:-DevTool}" 2>/dev/null

# ============================================================================
# PHASE 9: Reset the inter-quest counter so the next fetch waits another
# QUEST_EVERY_N user turns. Daily cap + cooldown live on the server, so
# we no longer track daily_quest_count / daily_reset_date locally.
# ============================================================================

python3 -c "
import json
import os
import tempfile

timing_file = os.path.expanduser('~/.sidequest/timing-state.json')
try:
    with open(timing_file) as f:
        timing_state = json.load(f)
except:
    timing_state = {}

timing_state['last_hook_fire'] = $CURRENT_TIME
timing_state['last_quest_shown'] = $CURRENT_TIME
timing_state['messages_since_last_quest'] = 0
# Drop legacy keys if present so the file shape matches the new schema.
timing_state.pop('daily_quest_count', None)
timing_state.pop('daily_reset_date', None)

# Atomic write: write to temp, then rename
os.makedirs(os.path.dirname(timing_file), exist_ok=True)
temp_fd, temp_path = tempfile.mkstemp(dir=os.path.dirname(timing_file))
try:
    with os.fdopen(temp_fd, 'w') as f:
        json.dump(timing_state, f)
    os.rename(temp_path, timing_file)
except:
    try:
        os.unlink(temp_path)
    except:
        pass
" 2>/dev/null

exit 0
