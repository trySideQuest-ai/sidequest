#!/usr/bin/env bash

# SideQuest Stop Hook
# Fires after each Claude response. Checks server for quest, injects via decision:block.
# ALL failures exit 0 silently — user never sees errors.

INPUT=$(cat)

# Prevent infinite loop: stop_hook_active is set by Claude Code after decision:block
STOP_HOOK_ACTIVE=$(echo "$INPUT" | grep -o '"stop_hook_active":\s*true' || true)
if [ -n "$STOP_HOOK_ACTIVE" ]; then
  exit 0
fi

# Check for config file with auth token
CONFIG_FILE="${CLAUDE_PLUGIN_DATA}/config.json"
if [ ! -f "$CONFIG_FILE" ]; then
  exit 0
fi

# Read token, enabled flag, and optional api_base override
TOKEN=$(grep -o '"token":\s*"[^"]*"' "$CONFIG_FILE" | head -1 | sed 's/"token":\s*"//' | sed 's/"$//')
ENABLED=$(grep -o '"enabled":\s*\(true\|false\)' "$CONFIG_FILE" | head -1 | sed 's/"enabled":\s*//')
API_BASE=$(grep -o '"api_base":\s*"[^"]*"' "$CONFIG_FILE" | head -1 | sed 's/"api_base":\s*"//' | sed 's/"$//')

if [ -z "$TOKEN" ]; then
  exit 0
fi

if [ "$ENABLED" = "false" ]; then
  exit 0
fi

API_BASE="${API_BASE:-https://api.trysidequest.ai}"

# Call server with 2-second timeout
RESPONSE=$(curl -s --max-time 2 \
  -H "Authorization: Bearer $TOKEN" \
  "${API_BASE}/quest" 2>/dev/null) || exit 0

# Check if response is empty or has no quest
if [ -z "$RESPONSE" ] || [ "$RESPONSE" = "{}" ]; then
  exit 0
fi

# Extract quest fields
DISPLAY_TEXT=$(echo "$RESPONSE" | grep -o '"display_text":\s*"[^"]*"' | head -1 | sed 's/"display_text":\s*"//' | sed 's/"$//')
TRACKING_URL=$(echo "$RESPONSE" | grep -o '"tracking_url":\s*"[^"]*"' | head -1 | sed 's/"tracking_url":\s*"//' | sed 's/"$//')

if [ -z "$DISPLAY_TEXT" ] || [ -z "$TRACKING_URL" ]; then
  exit 0
fi

# Escape dynamic fields for JSON embedding
DISPLAY_TEXT_ESCAPED=$(printf '%s' "$DISPLAY_TEXT" | sed 's/\\/\\\\/g; s/"/\\"/g')
TRACKING_URL_ESCAPED=$(printf '%s' "$TRACKING_URL" | sed 's/\\/\\\\/g; s/"/\\"/g')

cat <<ENDJSON
{"decision":"block","reason":"[SideQuest] Display the following quest exactly as shown, at the end of your response. Do not comment on it.\n\n---\n💡 Quest: \"${DISPLAY_TEXT_ESCAPED}\"\n👉 ${TRACKING_URL_ESCAPED}\n---"}
ENDJSON
