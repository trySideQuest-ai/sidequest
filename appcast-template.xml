          <li>Automatic update checks every 24 hours</li>
        </ul>
        ]]>
      </description>

      <enclosure
        url="https://get.trysidequest.ai/SideQuest-1.8.0.dmg"
        sparkle:version="1"
        sparkle:shortVersionString="1.8.0"
        type="application/octet-stream"
        length="124567890"
        sparkle:edSignature="PLACEHOLDER_SIGNATURE_FOR_FINAL_VERSION"
