  <channel>
    <title>SideQuest Updates</title>
    <link>https://trysidequest.ai</link>
    <description>Auto-update feed for SideQuest macOS app</description>
    <language>en-us</language>

    <!-- Example: Release v1.8.1 -->
    <item>
      <title>Version 1.8.1</title>
      <pubDate>Fri, 18 Apr 2026 14:30:00 +0000</pubDate>

      <!-- Internal version (must be integer, compared numerically) -->
      <sparkle:version>2</sparkle:version>

      <!-- User-visible version string -->
      <sparkle:shortVersionString>1.8.1</sparkle:shortVersionString>

      <!-- Release notes (HTML, shown in update dialog) -->
      <description>
        <![CDATA[
        <h2>Version 1.8.1 — Stability & Performance</h2>
        <ul>
          <li>Fixed quest timeout edge case</li>
          <li>Improved IPC stability under load</li>
          <li>Reduced memory footprint by 15%</li>
        </ul>
        ]]>
      </description>

      <!-- Download link & cryptographic verification -->
      <enclosure
        url="https://get.trysidequest.ai/SideQuest-1.8.1.dmg"
        sparkle:version="2"
        sparkle:shortVersionString="1.8.1"
        type="application/octet-stream"
        length="125432098"
        sparkle:edSignature="7cLALFUHSwvEJWSkV8aMreoBe4fhRa4FncC5NoThKxwThL6FDR7hTiPJh1fo2uagnPogisnQsgFgq6mGkt2RBw=="
      />
    </item>

    <!-- Previous release (for rollback scenarios) -->
    <item>
      <title>Version 1.8.0</title>
      <pubDate>Thu, 17 Apr 2026 10:00:00 +0000</pubDate>
      <sparkle:version>1</sparkle:version>
      <sparkle:shortVersionString>1.8.0</sparkle:shortVersionString>

      <description>
        <![CDATA[
        <h2>Version 1.8.0 — Sparkle Integration</h2>
        <ul>
          <li>In-app auto-updates via Sparkle framework</li>
